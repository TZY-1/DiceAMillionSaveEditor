<Window x:Class="DiceAMillionSaveEditor.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DiceAMillionSaveEditor.UI"
        xmlns:viewmodels="clr-namespace:DiceAMillionSaveEditor.UI.ViewModels"
        xmlns:converters="clr-namespace:DiceAMillionSaveEditor.UI.Converters"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
        mc:Ignorable="d"
        Title="Dice A Million — Save Editor" Height="750" Width="1050"
        Background="#0f1117" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:LogLevelToColorConverter x:Key="LogLevelToColorConverter"/>
        <converters:BoolToCheckSymbolConverter x:Key="BoolToCheckSymbolConverter"/>

        <!-- Accent colors -->
        <SolidColorBrush x:Key="AccentBlue" Color="#6366f1"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#22c55e"/>
        <SolidColorBrush x:Key="AccentAmber" Color="#f59e0b"/>
        <SolidColorBrush x:Key="CardBg" Color="#1a1d27"/>
        <SolidColorBrush x:Key="CardBorder" Color="#2a2d3a"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#e2e8f0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#94a3b8"/>
        <SolidColorBrush x:Key="InputBg" Color="#12141c"/>
        <SolidColorBrush x:Key="InputBorder" Color="#2a2d3a"/>

        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                BorderThickness="1" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
        </Style>

    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Panel: Configuration -->
        <Border Grid.Row="0" Background="{StaticResource CardBg}" CornerRadius="12" 
                Padding="20,16" Margin="0,0,0,16"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Margin="0,0,32,0" VerticalAlignment="Center">
                    <TextBlock Text="Save File Path" FontWeight="SemiBold" FontSize="12"
                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding SaveFilePath}" Style="{StaticResource ModernTextBox}"/>
                        <Button Grid.Column="1" Command="{Binding OpenSaveLocationCommand}" Margin="8,0,0,0" Padding="14,0"
                                Background="#334155" Style="{StaticResource ModernButton}" ToolTip="Open save directory">
                            <TextBlock Text="📁" FontSize="14" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Steam Profile URL" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"/>
                        <TextBlock Text="  (?)" FontSize="12" Foreground="{StaticResource AccentBlue}" 
                                   Cursor="Help" FontWeight="Bold">
                            <TextBlock.ToolTip>
                                <ToolTip MaxWidth="400">
                                    <StackPanel>
                                        <TextBlock Text="Your Steam Profile URL" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="12">
                                            Just paste the URL of your Steam profile. The app will automatically 
                                            fetch your achievement data for Dice A Million. Examples:
                                        </TextBlock>
                                        <TextBlock Text="https://steamcommunity.com/id/YourName/" 
                                                   FontFamily="Consolas" FontSize="11" Foreground="#6366f1" 
                                                   Margin="0,6,0,2" TextWrapping="Wrap"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#f59e0b" FontWeight="SemiBold">
                                            ⚠ Your profile must be set to Public.
                                        </TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </TextBlock.ToolTip>
                        </TextBlock>
                    </StackPanel>
                    <TextBox Text="{Binding SteamProfileUrl}" 
                             Style="{StaticResource ModernTextBox}"
                             ToolTip="z. B. https://steamcommunity.com/id/YourName/"/>
                </StackPanel>
                
                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Timeline Line Background -->
                    <Border Grid.Column="0" Width="2" Background="{StaticResource CardBorder}" 
                            HorizontalAlignment="Center" Margin="0,16,0,16"/>
                            
                    <!-- Timeline Steps & Buttons -->
                    <Grid Grid.Column="0" Grid.ColumnSpan="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Step 1 -->
                        <Border Grid.Row="0" Grid.Column="0" Width="24" Height="24" CornerRadius="12" 
                                Background="{StaticResource AccentBlue}" HorizontalAlignment="Left" Margin="8,0,0,16">
                            <TextBlock Text="1" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                        </Border>
                        <Button Grid.Row="0" Grid.Column="1" Content="Load Save File" Command="{Binding LoadSaveCommand}" 
                                Style="{StaticResource ModernButton}" Background="#20233e" Foreground="#a5b4fc"
                                Margin="40,0,0,16" Padding="16,8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>

                        <!-- Step 2 -->
                        <Border Grid.Row="1" Grid.Column="0" Width="24" Height="24" CornerRadius="12" 
                                Background="{StaticResource AccentGreen}" HorizontalAlignment="Left" Margin="8,0,0,16">
                            <TextBlock Text="2" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                        </Border>
                        <Button Grid.Row="1" Grid.Column="1" Content="Load Steam Achievements and patch save" Command="{Binding FetchAndApplyAchievementsCommand}" 
                                Style="{StaticResource ModernButton}" Background="#163824" Foreground="#86efac"
                                Margin="40,0,0,16" Padding="16,8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>

                        <!-- Step 3 -->
                        <Border Grid.Row="2" Grid.Column="0" Width="24" Height="24" CornerRadius="12" 
                                Background="{StaticResource AccentAmber}" HorizontalAlignment="Left" Margin="8,0,0,0">
                            <TextBlock Text="3" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                        </Border>
                        <Button Grid.Row="2" Grid.Column="1" Content="Save Changes" Command="{Binding SaveAndEncodeCommand}" 
                                Style="{StaticResource ModernButton}" Background="#422006" Foreground="#fcd34d"
                                Margin="40,0,0,0" Padding="16,8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Content -->
            <Border Grid.Column="0" Background="{StaticResource CardBg}" CornerRadius="12" 
                    Padding="16" Margin="0,0,12,0"
                    BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                <TabControl Background="Transparent" BorderThickness="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border Name="Border" Padding="12,8" Background="Transparent" BorderThickness="0,0,0,2" BorderBrush="Transparent" Margin="0,0,16,0" Cursor="Hand">
                                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" TextBlock.FontSize="13" TextBlock.FontWeight="SemiBold"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="False">
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>
                    
                    <TabItem Header="Savegame Data">
                        <Grid Margin="0,16,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Manual Edits (JSON Properties)" 
                                           FontWeight="SemiBold" FontSize="14" 
                                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                <!-- Search Box -->
                                <Grid Grid.Column="1" Width="260">
                                    <TextBox Text="{Binding SearchFilter, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource ModernTextBox}" 
                                             Padding="10,8,30,8"/>
                                    <TextBlock Text="🔍" FontSize="14" 
                                               HorizontalAlignment="Right" VerticalAlignment="Center" 
                                               Margin="0,0,10,0" IsHitTestVisible="False"
                                               Foreground="{StaticResource TextSecondary}"/>
                                </Grid>
                            </Grid>

                            <!-- Value hints legend -->
                <Border Grid.Row="1" Background="#12141c" CornerRadius="6" Padding="12,8" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Valid values:" FontSize="11" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextSecondary}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <Border Background="#1e2740" CornerRadius="4" Padding="8,3" Margin="0,0,6,0">
                            <TextBlock Text="new" FontFamily="Cascadia Code, Consolas" FontSize="11" Foreground="#60a5fa"/>
                        </Border>
                        <Border Background="#1e2740" CornerRadius="4" Padding="8,3" Margin="0,0,6,0">
                            <TextBlock Text="unseen" FontFamily="Cascadia Code, Consolas" FontSize="11" Foreground="#94a3b8"/>
                        </Border>
                        <Border Background="#1e3a2a" CornerRadius="4" Padding="8,3" Margin="0,0,6,0">
                            <TextBlock Text="seen" FontFamily="Cascadia Code, Consolas" FontSize="11" Foreground="#4ade80"/>
                        </Border>
                        <Border Background="#3a1e1e" CornerRadius="4" Padding="8,3" Margin="0,0,6,0">
                            <TextBlock Text="locked" FontFamily="Cascadia Code, Consolas" FontSize="11" Foreground="#f87171"/>
                        </Border>
                        <Border Background="#2a2d3a" CornerRadius="4" Padding="8,3" Margin="0,0,6,0">
                            <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="11" Foreground="#94a3b8">
                                <Run Text="0"/> <Run Text="/" Foreground="#4b5563"/> <Run Text="1.0"/>
                            </TextBlock>
                        </Border>
                        <TextBlock Text="  (for challenge completions)" FontSize="11" 
                                   Foreground="#4b5563" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="2" 
                          ItemsSource="{Binding FilteredProperties}" 
                          AutoGenerateColumns="False" CanUserAddRows="False" 
                          HeadersVisibility="Column"
                          RowDetailsVisibilityMode="Collapsed"
                          Background="Transparent" 
                          Foreground="{StaticResource TextPrimary}"
                          BorderThickness="0"
                          RowBackground="#12141c"
                          AlternatingRowBackground="#161922"
                          GridLinesVisibility="None"
                          FontFamily="Cascadia Code, Consolas, monospace"
                          FontSize="13"
                          RowHeight="36">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#1e2130"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                            <Setter Property="Padding" Value="14,10"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="14,8"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2a2d4a"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="MinHeight" Value="36"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2a2d4a"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1a1e2e"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Property Key" Binding="{Binding Key}" Width="3*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>
                </Grid>
                </TabItem>
                <TabItem Header="Steam Achievements">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Fetched Steam Achievements (Read-Only)"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center"/>
                            <Grid Grid.Column="1" Width="260">
                                <TextBox Text="{Binding AchievementSearchFilter, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}"
                                         Padding="10,8,30,8"/>
                                <TextBlock Text="🔍"
                                           FontSize="14"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           IsHitTestVisible="False"
                                           Foreground="{StaticResource TextSecondary}"/>
                            </Grid>
                        </Grid>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding FilteredAchievements}" 
                                  AutoGenerateColumns="False" CanUserAddRows="False" 
                                  HeadersVisibility="Column" RowDetailsVisibilityMode="Collapsed"
                                  Background="Transparent" Foreground="{StaticResource TextPrimary}"
                                  BorderThickness="0" RowBackground="#12141c" AlternatingRowBackground="#161922"
                                  GridLinesVisibility="None" FontFamily="Cascadia Code, Consolas, monospace"
                                  FontSize="13" RowHeight="36">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#1e2130"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                    <Setter Property="Padding" Value="14,10"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="14,8"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="MinHeight" Value="36"/>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Unlocked" Width="Auto" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Unlocked, Converter={StaticResource BoolToCheckSymbolConverter}}"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#ef4444"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Unlocked}" Value="True">
                                                                <Setter Property="Foreground" Value="#22c55e"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="API Name" Binding="{Binding ApiName}" Width="1.5*" IsReadOnly="True" Foreground="{StaticResource TextSecondary}"/>
                                <DataGridTextColumn Header="Achievement Name" Binding="{Binding Name}" Width="2*" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
                <TabItem Header="JSON Preview">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Decoded JSON (Loaded Save)"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,8"/>

                        <TextBox Grid.Row="1"
                                 Text="{Binding LoadedDecodedJson}"
                                 Style="{StaticResource ModernTextBox}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Margin="0,0,0,12"/>

                        <TextBlock Grid.Row="2"
                                   Text="Changed JSON (Current Edits)"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,8"/>

                        <TextBox Grid.Row="3"
                                 Text="{Binding ModifiedJson}"
                                 Style="{StaticResource ModernTextBox}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"/>
                    </Grid>
                </TabItem>
            </TabControl>
            </Border>

        <GridSplitter Grid.Column="1"
                      Width="8"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Columns"
                      Background="#2a2d3a"
                      ShowsPreview="True"
                      Cursor="SizeWE"/>

        <!-- Bottom Panel: Live Log -->
        <Border Grid.Column="2" Background="#0c0e14" CornerRadius="12" Padding="16" Margin="8,0,0,0"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <Ellipse Width="8" Height="8" Fill="#22c55e" Margin="0,0,6,0"/>
                    <TextBlock Text="Log Output" FontWeight="SemiBold" FontSize="12" 
                               Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>
                <RichTextBox Grid.Row="1"
                             x:Name="LogRichTextBox"
                             FontFamily="Cascadia Code, Consolas, monospace"
                             FontSize="12"
                             Foreground="{StaticResource TextPrimary}"
                             Background="Transparent"
                             BorderThickness="0"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"/>
            </Grid>
        </Border>
        </Grid>
        
        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="3" Background="#CC0f1117" 
              Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" 
              x:Name="LoadingOverlay">
            <Border Background="{StaticResource CardBg}" Padding="30,20" CornerRadius="12" 
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⏳" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Processing... Please wait." FontWeight="SemiBold" FontSize="15" 
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
